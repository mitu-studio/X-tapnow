# Public frontend variables (Vite only exposes variables with VITE_ prefix)
VITE_GEMINI_API_KEY=
# Backward compatibility (still supported by config)
GEMINI_API_KEY=

# Optional local dev proxy for /api/upload, example: http://127.0.0.1:8080
VITE_UPLOAD_PROXY_TARGET=

# Optional defaults for Sora character APIs (can also be configured in app settings)
VITE_SORA_API_BASE_URL=
VITE_SORA_CHARACTER_TOKEN=

# Optional dev server settings
VITE_DEV_SERVER_PORT=3000
VITE_DEV_SERVER_HOST=0.0.0.0
